<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="tri_bot">

  <!-- Inertia formulas -->
  <xacro:macro name="box_inertia" params="m w h d xyz rpy">
    <inertial>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <mass value="${m}"/>
      <inertia ixx="${(m/12) * (h*h + d*d)}" ixy="0.0" ixz="0.0"
               iyy="${(m/12) * (w*w + d*d)}" iyz="0.0"
               izz="${(m/12) * (w*w + h*h)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h xyz rpy">
    <inertial>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <mass value="${m}"/>
      <inertia ixx="${(m/12) * (3*r*r + h*h)}" ixy = "0.0" ixz = "0.0"
               iyy="${(m/12) * (3*r*r + h*h)}" iyz = "0.0"
               izz="${(m/2) * (r*r)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="m r xyz rpy">
    <inertial>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <mass value="${m}"/>
      <inertia ixx="${(2/5) * m * (r*r)}" ixy="0.0" ixz="0.0"
               iyy="${(2/5) * m * (r*r)}" iyz="0.0"
               izz="${(2/5) * m * (r*r)}"/>
    </inertial>
  </xacro:macro>

  <!-- All the values below are approximated -->
  <!-- The value indicates the length in meter -->
  <xacro:property name="body_length" value="0.16" />
  <xacro:property name="body_width" value="0.075" />
  <xacro:property name="single_wing_span" value="0.25" />
  <!-- Aileron: hinge at trailing edge; span runs along ±Y on each wing -->
  <xacro:property name="aileron_chord" value="0.04"/>
  <xacro:property name="aileron_span" value="0.08"/>
  <xacro:property name="aileron_thickness" value="0.004"/>
  <xacro:property name="aileron_hinge_y_frac" value="0.65"/>
  <xacro:property name="aileron_deflect_max" value="0.436"/>
  <xacro:property name="nose_length" value="0.08" />

  <xacro:property name="zoom_cam_size" value="0.019" />
  <xacro:property name="night_cam_size_x" value="0.02" />
  <xacro:property name="night_cam_size_y" value="0.02" />
  <xacro:property name="night_cam_size_z" value="0.02854" />
  <xacro:property name="cam_separation" value="0.04" />
  <!-- TVC mesh origin in link frame (CAD); link is fixed to rear of fuselage -->
  <xacro:property name="tvc_mesh_origin_x" value="-0.1858" />

  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="red">
    <color rgba="0.8 0 0 1"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1"/>
  </material>

  <!-- Dummy root link (no inertia) for KDL: robot_state_publisher warns if root has inertia -->
  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://tri_bot_description/mesh/EUN1_V7_fuselage_1.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <box size="${body_length} ${body_width} ${body_width}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="3" w="${body_length}" h="${body_width}" d="${body_width}" xyz="0 0 0" rpy="0 0 0"/>
  </link>

  <link name="camera_night_link">
    <visual>
      <geometry>
        <box size="${night_cam_size_x} ${night_cam_size_y} ${night_cam_size_z}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <xacro:box_inertia m="0.01" w="${night_cam_size_x}" h="${night_cam_size_y}" d="${night_cam_size_z}" xyz="0 0 0" rpy="0 0 0"/>
  </link>

  <joint name="camera_night_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_night_link"/>
    <origin xyz="${nose_length*0.8} ${cam_separation/2} 0" rpy="0 0 0"/>
  </joint>
  
  <link name="camera_zoom_link">
    <visual>
      <geometry>
        <cylinder radius="${zoom_cam_size/2}" length="${zoom_cam_size*1.5}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
      <material name="black"/>
    </visual>
    <xacro:box_inertia m="0.01" w="${zoom_cam_size*1.5}" h="${zoom_cam_size}" d="${zoom_cam_size}" xyz="0 0 0" rpy="0 0 0"/>
  </link>

  <joint name="camera_zoom_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_zoom_link"/>
    <origin xyz="${nose_length*0.8} -${cam_separation/2} 0" rpy="0 0 0"/>
  </joint>

  <!-- ROS 2 and cameras use 2 different coordinate systems -->
  <!-- The 2 optical frames uniform the standard to the one that ROS 2 uses -->
  <link name="camera_night_optical_frame"/>
  <joint name="camera_night_optical_joint" type="fixed">
    <parent link="camera_night_link"/>
    <child link="camera_night_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.57 0 -1.57"/>
  </joint>

  <link name="camera_zoom_optical_frame"/>
  <joint name="camera_zoom_optical_joint" type="fixed">
    <parent link="camera_zoom_link"/>
    <child link="camera_zoom_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.57 0 -1.57"/>
  </joint>

  <link name="left_wing">
    <visual>
      <geometry>
        <mesh filename="package://tri_bot_description/mesh/EUN1_V7_left_wing.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.1 ${single_wing_span} 0.02"/>
      </geometry>
      <origin xyz="0 ${single_wing_span/2} 0" rpy="0 0 0"/>
    </collision>
    <xacro:box_inertia m="0.05" w="0.1" h="${single_wing_span}" d="0.02" xyz="0 ${single_wing_span/2} 0" rpy="0 0 0"/>
  </link>

  <joint name="left_wing_fold_joint" type="revolute">
    <parent link="base_link"/>
    <child link="left_wing"/>
    <origin xyz="0.00651 0.0835 0.02567"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.57" upper="0" effort="10" velocity="1"/>
    <dynamics damping="5.0"/>
  </joint>

  <link name="left_aileron">
    <visual>
      <geometry>
        <mesh filename="package://tri_bot_description/mesh/EUN1_V7_left_aileron.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="${aileron_chord} ${aileron_span} ${aileron_thickness}"/>
      </geometry>
      <origin xyz="${aileron_chord/2} 0 0" rpy="0 0 0"/>
    </collision>
    <xacro:box_inertia m="0.008" w="${aileron_chord}" h="${aileron_span}" d="${aileron_thickness}"
      xyz="${aileron_chord/2} 0 0" rpy="0 0 0"/>
  </link>

  <joint name="left_aileron_joint" type="revolute">
    <parent link="left_wing"/>
    <child link="left_aileron"/>
    <origin xyz="-0.02451 0.0765 0.00623" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-${aileron_deflect_max}" upper="${aileron_deflect_max}" effort="5" velocity="3"/>
  </joint>

  <link name="left_propeller">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.004"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.02" length="0.004"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
    </collision>
    <xacro:cylinder_inertia m="0.01" r="0.02" h="0.004" xyz="0 0 0" rpy="0 1.57 0"/>
  </link>

  <joint name="left_propeller_joint" type="continuous">
    <parent link="left_wing"/>
    <child link="left_propeller"/>
    <origin xyz="" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.05"/>
  </joint>

  <link name="right_wing">
    <visual>
      <geometry>
        <mesh filename="package://tri_bot_description/mesh/EUN1_V7_right_wing.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.1 ${single_wing_span} 0.02"/>
      </geometry>
      <origin xyz="0 -${single_wing_span/2} 0" rpy="0 0 0"/>
    </collision>
    <xacro:box_inertia m="0.05" w="0.1" h="${single_wing_span}" d="0.02" xyz="0 -${single_wing_span/2} 0" rpy="0 0 0"/>
  </link>

  <joint name="right_wing_fold_joint" type="revolute">
    <parent link="base_link"/>
    <child link="right_wing"/>
    <origin xyz="0.00651 -0.0835 0.02567"/>
    <axis xyz="1 0 0"/> <limit lower="0" upper="1.57" effort="10" velocity="1"/>
    <dynamics damping="5.0"/>
  </joint>

  <link name="right_aileron">
    <visual>
      <geometry>
        <mesh filename="package://tri_bot_description/mesh/EUN1_V7_right_aileron.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="${aileron_chord} ${aileron_span} ${aileron_thickness}"/>
      </geometry>
      <origin xyz="${aileron_chord/2} 0 0" rpy="0 0 0"/>
    </collision>
    <xacro:box_inertia m="0.008" w="${aileron_chord}" h="${aileron_span}" d="${aileron_thickness}"
      xyz="${aileron_chord/2} 0 0" rpy="0 0 0"/>
  </link>

  <joint name="right_aileron_joint" type="revolute">
    <parent link="right_wing"/>
    <child link="right_aileron"/>
    <origin xyz="-0.02451 -0.0765 0.00623" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-${aileron_deflect_max}" upper="${aileron_deflect_max}" effort="5" velocity="3"/>
    <dynamics damping="0.5"/>
  </joint>

  <link name="right_propeller">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.004"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.02" length="0.004"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
    </collision>
    <xacro:cylinder_inertia m="0.01" r="0.02" h="0.004" xyz="0 0 0" rpy="0 1.57 0"/>
  </link>

  <joint name="right_propeller_joint" type="continuous">
    <parent link="right_wing"/>
    <child link="right_propeller"/>
    <origin xyz="" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.05"/>
  </joint>

  <link name="left_rudder">
    <visual>
      <geometry>
        <mesh filename="package://tri_bot_description/mesh/EUN1_V7_left_rudder.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.04 0.01 0.08"/>
      </geometry>
      <origin xyz="0.02 0 0" rpy="0 0 0"/>
    </collision>
    <xacro:box_inertia m="0.008" w="0.04" h="0.01" d="0.08" xyz="0.02 0 0" rpy="0 0 0"/>
  </link>

  <joint name="left_rudder_joint" type="revolute">
    <parent link="base_link"/>
    <child link="left_rudder"/>
    <origin xyz="-0.1817 0.0459 0.049" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.436" upper="0.436" effort="5" velocity="3"/>
    <dynamics damping="0.5"/>
  </joint>

  <link name="right_rudder">
    <visual>
      <geometry>
        <mesh filename="package://tri_bot_description/mesh/EUN1_V7_right_rudder.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.04 0.01 0.08"/>
      </geometry>
      <origin xyz="0.02 0 0" rpy="0 0 0"/>
    </collision>
    <xacro:box_inertia m="0.008" w="0.04" h="0.01" d="0.08" xyz="0.02 0 0" rpy="0 0 0"/>
  </link>

  <joint name="right_rudder_joint" type="revolute">
    <parent link="base_link"/>
    <child link="right_rudder"/>
    <origin xyz="-0.1817 -0.0459 0.049" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.436" upper="0.436" effort="5" velocity="3"/>
    <dynamics damping="0.5"/>
  </joint>

  <link name="wheel_frame">
    <visual>
      <geometry>
        <mesh filename="package://tri_bot_description/mesh/EUN1_V7_wheel_frame.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.12 0.12 0.06"/>
      </geometry>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
    </collision>
    <xacro:box_inertia m="0.15" w="0.12" h="0.12" d="0.06" xyz="0 0 -0.03" rpy="0 0 0"/>
  </link>

  <joint name="wheel_frame_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Landing gear wheels (meshes + placeholders; tune joint origins to CAD). -->
  <link name="wheel_fl">
    <visual>
      <geometry>
        <mesh filename="package://tri_bot_description/mesh/EUN1_V7_wheel_FL.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.015" length="0.012"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
    </collision>
    <xacro:cylinder_inertia m="0.02" r="0.015" h="0.012" xyz="0 0 0" rpy="0 1.57 0"/>
  </link>
  <joint name="wheel_fl_joint" type="continuous">
    <parent link="wheel_frame"/>
    <child link="wheel_fl"/>
    <origin xyz="0.06 0.05 -0.02" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.02"/>
  </joint>

  <link name="wheel_fr">
    <visual>
      <geometry>
        <mesh filename="package://tri_bot_description/mesh/EUN1_V7_wheel_FR.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.015" length="0.012"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
    </collision>
    <xacro:cylinder_inertia m="0.02" r="0.015" h="0.012" xyz="0 0 0" rpy="0 1.57 0"/>
  </link>
  <joint name="wheel_fr_joint" type="continuous">
    <parent link="wheel_frame"/>
    <child link="wheel_fr"/>
    <origin xyz="0.06 -0.05 -0.02" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.02"/>
  </joint>

  <link name="wheel_bl">
    <visual>
      <geometry>
        <mesh filename="package://tri_bot_description/mesh/EUN1_V7_wheel_BL.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.015" length="0.012"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
    </collision>
    <xacro:cylinder_inertia m="0.02" r="0.015" h="0.012" xyz="0 0 0" rpy="0 1.57 0"/>
  </link>
  <joint name="wheel_bl_joint" type="continuous">
    <parent link="wheel_frame"/>
    <child link="wheel_bl"/>
    <origin xyz="-0.06 0.05 -0.02" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.02"/>
  </joint>

  <link name="wheel_br">
    <visual>
      <geometry>
        <mesh filename="package://tri_bot_description/mesh/EUN1_V7_wheel_BR.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.015" length="0.012"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.57 0"/>
    </collision>
    <xacro:cylinder_inertia m="0.02" r="0.015" h="0.012" xyz="0 0 0" rpy="0 1.57 0"/>
  </link>
  <joint name="wheel_br_joint" type="continuous">
    <parent link="wheel_frame"/>
    <child link="wheel_br"/>
    <origin xyz="-0.06 -0.05 -0.02" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.02"/>
  </joint>

  <!-- TVC housing (STL) fixed to aft fuselage (no actuated TVC joints). -->
  <link name="tvc_link">
    <visual>
      <geometry>
        <mesh filename="package://tri_bot_description/mesh/EUN1_V7_TVC.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <origin xyz="${tvc_mesh_origin_x} 0 0" rpy="0 0 0"/>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.22 0.12 0.12"/>
      </geometry>
      <origin xyz="${tvc_mesh_origin_x} 0 0" rpy="0 0 0"/>
    </collision>
    <xacro:box_inertia m="0.08" w="0.22" h="0.12" d="0.12" xyz="${tvc_mesh_origin_x} 0 0" rpy="0 0 0"/>
  </link>

  <joint name="tvc_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="tvc_link"/>
    <origin xyz="0 0 0"/>
  </joint>

  <!-- IMU sensor on base_link (required by ArduPilotPlugin and useful for ROS 2). -->
  <link name="imu_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
  </link>
  <joint name="imu_joint" type="revolute">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="0" effort="0" velocity="0"/>
    <dynamics damping="1.0"/>
  </joint>
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <pose degrees="true">0 0 0 180 0 0</pose>
      <always_on>1</always_on>
      <update_rate>1000</update_rate>
    </sensor>
  </gazebo>

  <!-- ======= Control back-end selection =======
       use_ardupilot:=false  (default) → gz_ros2_control path
       use_ardupilot:=true              → ArduPilotPlugin path (for SITL) -->
  <xacro:arg name="use_ardupilot" default="false"/>

  <!-- ── ROS 2 control path ─────────────────────────────────────────── -->
  <xacro:unless value="$(arg use_ardupilot)">
    <xacro:arg name="controllers_file" default=""/>
    <ros2_control name="TriBotControl" type="system">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>
      <joint name="left_wing_fold_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="right_wing_fold_joint">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>
    <gazebo>
      <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <robot_param>robot_description</robot_param>
        <robot_param_node>robot_state_publisher</robot_param_node>
        <parameters>$(arg controllers_file)</parameters>
      </plugin>
    </gazebo>
  </xacro:unless>

  <!-- ── ArduPilot SITL path ─────────────────────────────────────────── -->
  <xacro:if value="$(arg use_ardupilot)">
    <gazebo>
      <plugin name="ArduPilotPlugin" filename="ArduPilotPlugin">
        <fdm_addr>127.0.0.1</fdm_addr>
        <fdm_port_in>9002</fdm_port_in>
        <connectionTimeoutMaxCount>5</connectionTimeoutMaxCount>
        <lock_step>1</lock_step>

        <!-- tri_bot body frame: X-forward, Y-left, Z-up (ROS REP-103).
             ArduPilot NED: X-forward, Y-right, Z-down.
             Rotation from Gazebo model frame to ArduPilot body: 180 deg roll. -->
        <modelXYZToAirplaneXForwardZDown degrees="true">0 0 0 180 0 0</modelXYZToAirplaneXForwardZDown>
        <gazeboXYZToNED degrees="true">0 0 0 180 0 90</gazeboXYZToNED>

        <imuName>imu_link::imu_sensor</imuName>

        <!-- CH1 (SERVO1): left wing fold — POSITION servo -->
        <control channel="0">
          <jointName>left_wing_fold_joint</jointName>
          <useForce>1</useForce>
          <multiplier>-3.14</multiplier>
          <offset>-0.5</offset>
          <servo_min>1100</servo_min>
          <servo_max>1900</servo_max>
          <type>POSITION</type>
          <p_gain>10.0</p_gain>
          <i_gain>0</i_gain>
          <d_gain>0</d_gain>
          <i_max>0</i_max>
          <i_min>0</i_min>
          <cmd_max>0.0</cmd_max>
          <cmd_min>-1.57</cmd_min>
        </control>

        <!-- CH2 (SERVO2): right wing fold — POSITION servo -->
        <control channel="1">
          <jointName>right_wing_fold_joint</jointName>
          <useForce>1</useForce>
          <multiplier>3.14</multiplier>
          <offset>-0.5</offset>
          <servo_min>1100</servo_min>
          <servo_max>1900</servo_max>
          <type>POSITION</type>
          <p_gain>10.0</p_gain>
          <i_gain>0</i_gain>
          <d_gain>0</d_gain>
          <i_max>0</i_max>
          <i_min>0</i_min>
          <cmd_max>1.57</cmd_max>
          <cmd_min>0.0</cmd_min>
        </control>
      </plugin>
    </gazebo>

    <!-- Publish joint states so ArduPilotPlugin can read JointPosition components -->
    <gazebo>
      <plugin filename="gz-sim-joint-state-publisher-system"
        name="gz::sim::systems::JointStatePublisher">
      </plugin>
    </gazebo>

    <!-- ApplyJointForce required for each joint ArduPilot drives -->
    <gazebo>
      <plugin filename="gz-sim-apply-joint-force-system" name="gz::sim::systems::ApplyJointForce">
        <joint_name>left_wing_fold_joint</joint_name>
      </plugin>
    </gazebo>
    <gazebo>
      <plugin filename="gz-sim-apply-joint-force-system" name="gz::sim::systems::ApplyJointForce">
        <joint_name>right_wing_fold_joint</joint_name>
      </plugin>
    </gazebo>
  </xacro:if>
</robot>